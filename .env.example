# Copy to .env — never commit .env to git

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# The Odds API — live odds, 500 req/month free
# Get key: https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# ── OPTIONAL — live scores ────────────────────────────────────────────────────
# football-data.org — free tier covers PL, La Liga, Bundesliga, Serie A, Ligue 1
# Get key: https://www.football-data.org
FOOTBALL_DATA_KEY=your_football_data_key_here

# ── OPTIONAL — xG enrichment ─────────────────────────────────────────────────
# api-football.com — 100 req/day free
# Get key: https://www.api-football.com
API_FOOTBALL_KEY=your_api_football_key_here

# ── OPTIONAL — bet placement ─────────────────────────────────────────────────
SPORTYBET_USERNAME=your_phone_or_email
SPORTYBET_PASSWORD=your_password

# ── Bot settings ──────────────────────────────────────────────────────────────
DRY_RUN=true
BANKROLL=1000
MIN_EDGE=0.03
KELLY_FRACTION=0.25
ACCA_FOLDS=3,5,7
ML_BLEND=0.4
